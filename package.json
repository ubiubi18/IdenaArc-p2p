{
  "name": "idena-arc",
  "productName": "IdenaArc",
  "version": "0.1.0",
  "description": "Rehearsal-first Idena ARC-style game generation and annotation client.",
  "main": "main/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/ubiubi18/IdenaArc-p2p.git"
  },
  "homepage": "https://github.com/ubiubi18/IdenaArc-p2p#readme",
  "bugs": {
    "url": "https://github.com/ubiubi18/IdenaArc-p2p/issues"
  },
  "author": "ubiubi18",
  "license": "MIT",
  "engines": {
    "node": ">=24.15.0 <25",
    "npm": ">=11.12.0"
  },
  "scripts": {
    "preinstall": "node scripts/check-runtime-install.js",
    "postinstall": "node scripts/rebuild-electron-runtime-deps.js",
    "start": "dotenv -e .env.local node scripts/start-electron-dev.js",
    "build:social": "npm ci --prefix vendor/idena.social-ui && npm run build --prefix vendor/idena.social-ui && node scripts/sync-idena-social-ui.js",
    "build:renderer": "node scripts/run-next-static-build.js",
    "build": "npm run build:social && npm run build:renderer",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win --publish onTag",
    "dist:mac": "npm run build && electron-builder --mac --publish onTag",
    "dist:mac:arm64": "npm run build && electron-builder --mac --arm64 --publish onTag",
    "dist:mac:universal": "npm run build && electron-builder --mac --universal --publish onTag",
    "dist:linux": "npm run build && electron-builder --linux --publish onTag",
    "pack": "npm run build && electron-builder --dir",
    "pack:mac:arm64": "npm run build && electron-builder --dir --mac --arm64",
    "pack:mac:universal": "npm run build && electron-builder --dir --mac --universal",
    "clean": "node scripts/clean-paths.js renderer/out renderer/.next dist",
    "audit:privacy": "node scripts/check-release-privacy.js",
    "audit:metadata": "node scripts/check-release-metadata.js",
    "audit:artifacts": "node scripts/check-release-artifacts.js",
    "audit:deps": "node scripts/check-dependency-footprint.js",
    "audit:electron": "node scripts/check-electron-safety.js",
    "build:node:mac:arm64": "idena-go/scripts/build-node-macos-arm64.sh \"$HOME/Library/Application Support/IdenaArc/node/idena-go\"",
    "release:check": "node scripts/release-check.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest",
    "test:idena-arc:python": "python3 -m unittest python/idena_arc/test_arc_sidecar.py",
    "test:idena-go:validation": "idena-go/scripts/run-go-toolchain.sh test ./config ./database ./api ./core/ceremony",
    "test:idena-go:wasm": "idena-go/scripts/run-go-toolchain.sh test ./vm/wasm -count=1",
    "index:deep-research": "node scripts/run-python.js scripts/build_deep_research_index.py",
    "playwright:close": "bash scripts/close-playwright-browser.sh",
    "i18n:init": "npm run i18n:clean && npm run i18n:scan",
    "i18n:scan": "i18next-scanner",
    "i18n:clean": "node scripts/clean-paths.js locales/en locales/id locales/fr locales/de locales/es locales/ru locales/zh locales/ko locales/hr locales/hi locales/ro locales/uk locales/sr locales/it locales/pt locales/pl locales/si locales/tr locales/bg locales/sv locales/ja locales/el",
    "e2e": "node scripts/e2e-disabled.js"
  },
  "build": {
    "appId": "io.idena.arc",
    "artifactName": "idena-arc-${os}-${version}.${ext}",
    "npmRebuild": false,
    "asarUnpack": [
      "python/**"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "ubiubi18",
        "repo": "IdenaArc-p2p"
      }
    ],
    "files": [
      "**/*",
      "!**/.env",
      "!**/.env.*",
      "!**/*.log",
      "!.tmp",
      "!.tmp/**",
      "!tmp",
      "!tmp/**",
      "!data",
      "!data/**",
      "!logs",
      "!logs/**",
      "!coverage",
      "!coverage/**",
      "!.nyc_output",
      "!.nyc_output/**",
      "!vendor",
      "!vendor/**",
      "!downloads",
      "!downloads/**",
      "!renderer",
      "renderer/out"
    ],
    "protocols": {
      "name": "idena",
      "schemes": [
        "dna"
      ]
    },
    "win": {
      "icon": "main/static/icons/icon_512_2x.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "main/static/icons/icon-512@2x.icns"
    },
    "linux": {
      "target": [
        "deb"
      ],
      "icon": "main/static/icons/icon-512@2x.icns",
      "maintainer": "Idena <info@idena.io> (https://idena.io/)"
    }
  },
  "devDependencies": {
    "@babel/core": "^7.6.0",
    "@electron/rebuild": "^4.0.4",
    "@testing-library/react": "^9.1.4",
    "babel-eslint": "^10.0.1",
    "babel-jest": "^29.7.0",
    "cors": "^2.8.5",
    "dotenv-cli": "3.1.0",
    "electron": "41.3.0",
    "electron-builder": "^26.8.2",
    "eslint": "^8.36.0",
    "eslint-config-wesbos": "^3.2.3",
    "express": "^4.17.1",
    "i18next-scanner": "^2.10.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "next": "^9.5.1",
    "next-google-fonts": "^1.2.1",
    "prettier": "^2.8.7",
    "react-dom": "^16.8.4"
  },
  "dependencies": {
    "@chakra-ui/react": "^1.0.0",
    "@emotion/react": "^11.0.0",
    "@emotion/styled": "^11.0.0",
    "@xstate/react": "^3.2.1",
    "ansi-to-react": "^6.0.5",
    "canvas-confetti": "^1.4.0",
    "color-convert": "^2.0.1",
    "dayjs": "^1.9.6",
    "dequal": "^1.0.0",
    "dexie": "^3.2.2",
    "electron-updater": "^6.8.3",
    "extract-colors": "^1.1.22",
    "framer-motion": "^4.0.0",
    "fs-extra": "^8.1.0",
    "google-protobuf": "^3.14.0",
    "i18next": "^19.0.1",
    "js-sha3": "^0.8.0",
    "leveldown": "^5.6.0",
    "levelup": "^4.4.0",
    "lowdb": "^1.0.0",
    "mousetrap": "^1.6.3",
    "multiformats": "^9.7.1",
    "nanoid": "^3.3.11",
    "pino": "^5.13.2",
    "qrcode.react": "^0.9.3",
    "react": "^16.8.4",
    "react-beautiful-dnd": "^10.0.4",
    "react-i18next": "^11.2.5",
    "react-query": "^3.39.0",
    "react-scroll": "^1.8.7",
    "react-swipeable": "^7.0.0",
    "rlp": "^2.2.2",
    "semver": "^7.7.2",
    "stackblur-canvas": "^2.5.0",
    "subleveldown": "^5.0.1",
    "tree-kill": "^1.2.2",
    "url-regex-safe": "^3.0.0",
    "xstate": "^4.37.1"
  },
  "overrides": {
    "@babel/runtime": "^7.26.10",
    "@babel/runtime-corejs3": "^7.26.10",
    "@tootallnate/once": "^3.0.1",
    "braces": "^3.0.3",
    "browserslist": "^4.26.3",
    "elliptic": {
      ".": "^6.6.1",
      "bn.js": "4.12.3"
    },
    "loader-utils": "^2.0.4",
    "minimatch": "^3.1.5",
    "node-fetch": "^2.7.0",
    "object-path": "^0.11.8",
    "serialize-javascript": "^7.0.5",
    "shell-quote": "^1.8.3",
    "tar": "^7.5.13",
    "terser": "^4.8.1"
  },
  "prettier": {
    "trailingComma": "es5",
    "semi": false,
    "singleQuote": true,
    "bracketSpacing": false
  }
}
