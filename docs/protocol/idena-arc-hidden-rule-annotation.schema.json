{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://idena-arc.local/protocol/idena-arc-hidden-rule-annotation.schema.json",
  "title": "IdenaArc Hidden Rule Annotation",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "protocol",
    "status",
    "sessionId",
    "resultId",
    "participantId",
    "traceHash",
    "recordingHash",
    "agentLogHash",
    "finalSeedHash",
    "humanRuleAnnotation",
    "aiSelfAnnotation",
    "comparisonAnnotation"
  ],
  "properties": {
    "protocol": {"const": "idena-arc-annotation-bundle-v0"},
    "access": {"const": "local-only-private-by-default"},
    "releasePolicy": {"const": "private-by-default-explicit-publish-only"},
    "status": {"enum": ["draft", "final"]},
    "sessionId": {"type": "string", "minLength": 1},
    "resultId": {"type": "string", "minLength": 1},
    "participantId": {"type": "string", "minLength": 1},
    "traceHash": {"$ref": "#/$defs/sha256Prefixed"},
    "recordingHash": {"$ref": "#/$defs/sha256Prefixed"},
    "recordingJsonlHash": {"$ref": "#/$defs/sha256Prefixed"},
    "agentLogHash": {"$ref": "#/$defs/sha256Prefixed"},
    "finalSeedHash": {"$ref": "#/$defs/sha256Prefixed"},
    "generatorHash": {"$ref": "#/$defs/sha256Prefixed"},
    "humanRuleAnnotation": {
      "type": "object",
      "required": ["protocol", "confirmedRules", "recognitionMoment"],
      "properties": {
        "protocol": {"const": "idena-arc-hidden-rule-annotation-v0"},
        "status": {"enum": ["draft", "final"]},
        "ruleHypotheses": {"type": "array", "items": {"type": "string"}},
        "confirmedRules": {"type": "array", "items": {"type": "string"}},
        "evidenceEvents": {
          "type": "array",
          "items": {"$ref": "#/$defs/evidenceEvent"}
        },
        "recognitionMoment": {"type": "object"},
        "wrongHypotheses": {"type": "array", "items": {"type": "string"}},
        "strategyChange": {"type": "string"},
        "difficulty": {"type": ["integer", "null"], "minimum": 1, "maximum": 5},
        "teachingNotes": {"type": "string"},
        "capabilityTags": {"type": "array", "items": {"type": "string"}}
      }
    },
    "aiSelfAnnotation": {"$ref": "#/$defs/aiSelfAnnotation"},
    "comparisonAnnotation": {
      "type": "object",
      "required": ["protocol"],
      "properties": {
        "protocol": {"const": "idena-arc-comparison-annotation-v0"},
        "status": {"enum": ["draft", "final"]},
        "humanVsAiGap": {"type": "string"},
        "capabilityTags": {"type": "array", "items": {"type": "string"}},
        "suggestedAdapterTarget": {"type": "string"},
        "actionButtonComparison": {
          "type": "object",
          "properties": {
            "protocol": {"const": "idena-arc-action-button-comparison-v0"},
            "rule": {"type": "string"},
            "buttons": {
              "type": "array",
              "items": {
                "allOf": [
                  {"$ref": "#/$defs/actionButtonDescription"},
                  {
                    "type": "object",
                    "properties": {
                      "usedBy": {
                        "type": "object",
                        "properties": {
                          "human": {"type": "boolean"},
                          "localAi": {"type": "boolean"}
                        }
                      }
                    }
                  }
                ]
              }
            }
          }
        }
      }
    },
    "localAiGameplayAnnotation": {"$ref": "#/$defs/gameplayAnnotation"},
    "humanReplayAnnotation": {"$ref": "#/$defs/replayAnnotation"},
    "frameContext": {"$ref": "#/$defs/frameContext"},
    "annotationValidation": {"$ref": "#/$defs/annotationValidation"}
  },
  "$defs": {
    "sha256Prefixed": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "aiSelfAnnotation": {
      "type": "object",
      "required": ["protocol"],
      "properties": {
        "protocol": {"const": "idena-arc-ai-self-annotation-v0"},
        "status": {"enum": ["draft", "final"]},
        "attemptedHypotheses": {"type": "array", "items": {"type": "string"}},
        "evidenceUsed": {"type": "array", "items": {"type": "string"}},
        "uncertaintyReducingActions": {
          "type": "array",
          "items": {"type": "string"}
        },
        "repeatedLoops": {"type": "array", "items": {"type": "string"}},
        "failedAbstractions": {"type": "array", "items": {"type": "string"}},
        "finalKnownState": {"type": "string"},
        "stopReason": {"type": "string"},
        "missingCapability": {"type": "string"}
      }
    },
    "noemonStyleAnnotation": {
      "type": "object",
      "required": ["protocol"],
      "properties": {
        "protocol": {"const": "idena-arc-noemon-style-annotation-v0"},
        "role": {"type": "string"},
        "summary": {"type": "string"},
        "gridSize": {"type": "string"},
        "invariants": {"type": "array", "items": {"type": "string"}},
        "ruleHypothesis": {"type": "string"},
        "transformationAlgorithm": {"type": "string"},
        "actionPolicy": {"type": "string"},
        "rejectedAlternatives": {"type": "array", "items": {"type": "string"}},
        "evidenceEvents": {
          "type": "array",
          "items": {"$ref": "#/$defs/evidenceEvent"}
        },
        "filledFieldCount": {"type": "integer", "minimum": 0}
      }
    },
    "compression": {
      "type": "object",
      "properties": {
        "protocol": {"const": "idena-arc-explanation-compression-v0"},
        "sourceTextHash": {"type": ["string", "null"]},
        "compressedText": {"type": "string"},
        "compressedTextHash": {"type": ["string", "null"]},
        "lossy": {"type": "boolean"}
      }
    },
    "gameplayAnnotation": {
      "type": "object",
      "properties": {
        "protocol": {"const": "idena-arc-local-ai-gameplay-annotation-v0"},
        "attemptedActions": {"type": "array", "items": {"type": "object"}},
        "actionButtonDescriptions": {
          "type": "array",
          "items": {"$ref": "#/$defs/actionButtonDescription"}
        },
        "explanationText": {"type": "string"},
        "structuredExplanation": {"$ref": "#/$defs/noemonStyleAnnotation"},
        "compression": {"$ref": "#/$defs/compression"},
        "structuredCompression": {"$ref": "#/$defs/compression"}
      }
    },
    "replayAnnotation": {
      "type": "object",
      "properties": {
        "protocol": {"const": "idena-arc-human-replay-annotation-v0"},
        "replayActions": {"type": "array", "items": {"type": "object"}},
        "actionButtonDescriptions": {
          "type": "array",
          "items": {"$ref": "#/$defs/actionButtonDescription"}
        },
        "explanationText": {"type": "string"},
        "structuredExplanation": {"$ref": "#/$defs/noemonStyleAnnotation"},
        "keyMoments": {
          "type": "array",
          "items": {"$ref": "#/$defs/evidenceEvent"}
        },
        "corrections": {"type": "array", "items": {"type": "string"}},
        "compression": {"$ref": "#/$defs/compression"},
        "structuredCompression": {"$ref": "#/$defs/compression"}
      }
    },
    "actionButtonDescription": {
      "type": "object",
      "properties": {
        "protocol": {"const": "idena-arc-action-button-description-v0"},
        "action": {"type": "string"},
        "buttonLabel": {"type": "string"},
        "keys": {"type": "array", "items": {"type": "string"}},
        "description": {"type": "string"}
      }
    },
    "evidenceEvent": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "actionIndex": {"type": ["integer", "null"], "minimum": 0},
        "t_ms": {"type": ["integer", "null"], "minimum": 0},
        "description": {"type": "string"},
        "observationHash": {"type": "string"},
        "visualMarker": {"$ref": "#/$defs/visualMarker"}
      }
    },
    "visualMarker": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "protocol": {"const": "idena-arc-visual-marker-v0"},
        "markerId": {"type": "string"},
        "label": {"type": "string"},
        "x": {"type": ["integer", "null"], "minimum": 0},
        "y": {"type": ["integer", "null"], "minimum": 0},
        "frameWidth": {"type": ["integer", "null"], "minimum": 1},
        "frameHeight": {"type": ["integer", "null"], "minimum": 1},
        "role": {"type": "string"},
        "note": {"type": "string"}
      }
    },
    "frameContext": {
      "type": "object",
      "properties": {
        "protocol": {"const": "idena-arc-compact-frame-context-v0"},
        "source": {"type": "string"},
        "gameId": {"type": "string"},
        "entryCount": {"type": "integer", "minimum": 0},
        "actionCount": {"type": "integer", "minimum": 0},
        "initial": {"type": ["object", "null"]},
        "final": {"type": ["object", "null"]},
        "milestones": {"type": "array", "items": {"type": "object"}},
        "actionTrace": {"type": "array", "items": {"type": "object"}}
      }
    },
    "annotationValidation": {
      "type": "object",
      "properties": {
        "protocol": {"const": "idena-arc-annotation-validation-v0"},
        "strategy": {"type": "string"},
        "status": {"enum": ["usable-for-training", "needs-more-annotation"]},
        "readinessScore": {"type": "number", "minimum": 0, "maximum": 1},
        "checks": {"type": "array", "items": {"type": "object"}},
        "feedback": {"type": "array", "items": {"type": "string"}},
        "replayPrefixTask": {"type": "object"}
      }
    }
  }
}
