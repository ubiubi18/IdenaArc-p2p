{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://idena-arc.local/protocol/idena-arc-ingredient-commitment.schema.json",
  "title": "IdenaArc Game Ingredient Commitment",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol",
    "version",
    "sessionId",
    "createdAt",
    "producerAddress",
    "ingredientKind",
    "publicInterface",
    "payloadAvailability",
    "commitmentHash",
    "signature"
  ],
  "properties": {
    "protocol": {"const": "idena-arc-ingredient-commitment-v0"},
    "version": {"const": 0},
    "sessionId": {"type": "string", "minLength": 1, "maxLength": 160},
    "createdAt": {"type": "string", "format": "date-time"},
    "producerAddress": {"$ref": "#/$defs/address"},
    "producerIdentityStatus": {"type": ["string", "null"], "maxLength": 80},
    "ingredientKind": {
      "enum": [
        "action",
        "path",
        "template_overlay",
        "path_dependent_action",
        "object_role",
        "scoring",
        "salt_slot",
        "mixed"
      ]
    },
    "publicInterface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provides",
        "requires",
        "complexity",
        "budgetImpact",
        "fallbackBehavior"
      ],
      "properties": {
        "provides": {
          "type": "array",
          "items": {"type": "string", "minLength": 1, "maxLength": 120}
        },
        "requires": {
          "type": "array",
          "items": {"type": "string", "minLength": 1, "maxLength": 120}
        },
        "complexity": {"type": "integer", "minimum": 1, "maximum": 10},
        "budgetImpact": {
          "type": "object",
          "additionalProperties": false,
          "required": ["minExtraActions", "maxExtraActions"],
          "properties": {
            "minExtraActions": {
              "type": "integer",
              "minimum": 0,
              "maximum": 512
            },
            "maxExtraActions": {"type": "integer", "minimum": 0, "maximum": 512}
          }
        },
        "fallbackBehavior": {
          "enum": [
            "drop_card",
            "drop_ingredient",
            "generator_catalog_fill",
            "replace_with_noop"
          ]
        },
        "templateOverlayContract": {"$ref": "#/$defs/templateOverlayContract"},
        "conflictTags": {
          "type": "array",
          "items": {"type": "string", "minLength": 1, "maxLength": 120}
        }
      }
    },
    "payloadHash": {"$ref": "#/$defs/sha256PrefixedOrNull"},
    "payloadAvailability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requiredAtT0", "missingPayloadPolicy"],
      "properties": {
        "requiredAtT0": {"const": false},
        "availableBeforeCutoff": {"type": ["boolean", "null"]},
        "replicationDeadline": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "missingPayloadPolicy": {
          "enum": [
            "ignore_overlay",
            "generator_catalog_fill",
            "replace_with_noop"
          ]
        }
      }
    },
    "commitmentHash": {"$ref": "#/$defs/sha256Prefixed"},
    "revealPolicy": {"const": "salt-reveal-only-at-session-constitution"},
    "signature": {"$ref": "#/$defs/signature"}
  },
  "$defs": {
    "address": {"type": "string", "pattern": "^0x[a-fA-F0-9]{40}$"},
    "sha256Prefixed": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "sha256PrefixedOrNull": {
      "anyOf": [
        {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
        {"type": "null"}
      ]
    },
    "templateOverlayContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "templateFamily",
        "width",
        "height",
        "entryPorts",
        "exitPorts",
        "minSolutionActions",
        "maxSolutionActions",
        "requiredAtT0",
        "missingPayloadPolicy"
      ],
      "properties": {
        "templateFamily": {"type": "string", "minLength": 1, "maxLength": 120},
        "width": {"type": "integer", "minimum": 1, "maximum": 16},
        "height": {"type": "integer", "minimum": 1, "maximum": 16},
        "entryPorts": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/overlayPort"}
        },
        "exitPorts": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/overlayPort"}
        },
        "minSolutionActions": {"type": "integer", "minimum": 0, "maximum": 512},
        "maxSolutionActions": {"type": "integer", "minimum": 1, "maximum": 512},
        "requiredCapabilities": {
          "type": "array",
          "items": {"type": "string", "minLength": 1, "maxLength": 120}
        },
        "conflictTags": {
          "type": "array",
          "items": {"type": "string", "minLength": 1, "maxLength": 120}
        },
        "requiredAtT0": {"const": false},
        "missingPayloadPolicy": {
          "enum": [
            "ignore_overlay",
            "generator_catalog_fill",
            "replace_with_noop"
          ]
        }
      }
    },
    "overlayPort": {
      "enum": ["north", "east", "south", "west", "start", "goal"]
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "address", "messageHash", "value"],
      "properties": {
        "type": {"enum": ["idena-node-dna-sign-v1", "idena-arc-secp256k1-v0"]},
        "address": {"$ref": "#/$defs/address"},
        "messageHash": {"type": "string", "minLength": 1},
        "value": {"type": "string", "minLength": 1}
      }
    }
  }
}
