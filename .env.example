# Copy this file to .env.local for local development.
# Do not commit .env.local or provider API keys.

# Main provider defaults. API keys are loaded in the app UI as session-only keys.
IDENAAI_PROVIDER_DEFAULT=openai
IDENAAI_OPENAI_MODEL=gpt-5.5
IDENAAI_GEMINI_MODEL=gemini-2.0-flash

# Optional Python story pipeline. Keep disabled unless you installed requirements.txt.
IDENAAI_USE_PY_FLIP_PIPELINE=false
IDENAAI_PYTHON=python3

# Benchmark logging controls.
IDENAAI_BENCH_LOGGING=true
IDENAAI_BENCH_LOG_MAX_MB=200
